{
  "version": 2,
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "**/*.css", "use": "@vercel/static" },
    { "src": "image/**", "use": "@vercel/static" },
    { "src": "resume/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/aboutme/?$", "dest": "/aboutme.html" },
    { "src": "^/portfolio/?$", "dest": "/portfolio.html" },
    { "src": "^/skills/?$", "dest": "/skills.html" },
    { "src": "^/contact/?$", "dest": "/contact.html" }
  ],
  "cleanUrls": true
}
